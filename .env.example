# Supabase Configuration
# Get these values from your Supabase project dashboard at https://app.supabase.com

# Your Supabase project URL (find in: Settings → API → Project URL)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous/public key (find in: Settings → API → Project API keys → anon public)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ===================================
# SETUP INSTRUCTIONS
# ===================================
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual Supabase credentials
# 3. Never commit the .env file to version control (it's in .gitignore)
#
# To create a new Supabase project:
# 1. Go to https://app.supabase.com
# 2. Click "New Project"
# 3. Once created, find your credentials in Settings → API
